# Copy this file to scripts/.env.deploy and fill in your values.
# Then run: source scripts/.env.deploy && ./scripts/deploy.sh --all
#
# NEVER commit .env.deploy — it contains your HA token.

# Home Assistant address
export HA_HOST="192.168.1.100"      # or homeassistant.local
export HA_PORT="8123"

# Long-Lived Access Token
# Create at: HA → Profile → Security → Long-lived access tokens
export HA_TOKEN="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Path to HA config directory (the folder containing configuration.yaml)
export HA_CONFIG_DIR="/config"       # typical for HA OS / Docker
# export HA_CONFIG_DIR="$HOME/.homeassistant"  # typical for venv install

# SSH deploy (leave HA_SSH_USER empty for local filesystem deploy)
export HA_SSH_USER="root"           # or "homeassistant"
export HA_SSH_PORT="22"

# Python venv for tests (relative to repo root)
export VENV_PATH=".venv"
